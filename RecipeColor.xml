	xsi:schemaLocation = "http://www.blizzard.com/wow/ui/C:\Projects\WoW\Bin\Interface\FrameXML\UI.xsd">

<Frame name = "RecipeColor" parent = "UIParent" hidden = "false">
	<Scripts>
		<OnLoad>
			RecipeColor_OnLoad(self)
		</OnLoad>
		<OnEvent>
			RecipeColor_OnEvent(self, event, arg1)
		</OnEvent>
	</Scripts>
</Frame>

<GameTooltip name = "RecipeColor_ScanTooltip" inherits = "GameTooltipTemplate">
	<Scripts>
		<OnLoad>
			self:SetOwner(WorldFrame, "ANCHOR_NONE")
		</OnLoad>
	</Scripts>
</GameTooltip>
</Ui>
